      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ==========================================\n",
        "#  USER INPUTS: DEFINE YOUR PROPERTY HERE\n",
        "# ==========================================\n",
        "\n",
        "current_price = 350000  # Current market value in GBP\n",
        "years = 15              # Forecast horizon (e.g., 2025 to 2040)\n",
        "\n",
        "# 1. AFFORDABILITY HEADROOM (Price-to-Earnings Ratio)\n",
        "# Options: 'High_Headroom' (North/Scotland/Wales - PE < 6x)\n",
        "#          'Neutral' (Midlands/South West - PE ~ 7-8x)\n",
        "#          'Maxed_Out' (London/South East - PE > 10x)\n",
        "affordability_status = 'Neutral'\n",
        "\n",
        "# 2. AGGLOMERATION (Local Economy Quality)\n",
        "# Options: 'Tech_Hub' (Cambridge, Manchester, Bristol, London Z1)\n",
        "#          'Average' (Standard Commuter Town)\n",
        "#          'Stagnant' (Post-industrial, low job growth)\n",
        "local_economy = 'Tech_Hub'\n",
        "\n",
        "# 3. PROPERTY TENURE & TYPE\n",
        "# Options: 'Freehold_House' (Scarcity value, no service charge)\n",
        "#          'Leasehold_Flat' (Service charge friction, supply glut risk)\n",
        "property_type = 'Freehold_House'\n",
        "\n",
        "# 4. CLIMATE & INSURANCE RISK\n",
        "# Options: 'Low' (Inland, hill, standard insurance)\n",
        "#          'High' (Flood plain, coastal erosion risk, difficult to insure)\n",
        "climate_risk = 'Low'\n",
        "\n",
        "# ==========================================\n",
        "#  SCENARIO DEFINITIONS (THE MACRO LAYER)\n",
        "# ==========================================\n",
        "# Base Annual Growth Rates (Real Terms + Inflation)\n",
        "# These are the \"Tide\" that lifts or drops all boats.\n",
        "\n",
        "scenarios = {\n",
        "    \"New Gilded Age\": {\n",
        "        \"base_rate\": 0.07,  # 7% annual growth (High inflation + Real growth)\n",
        "        \"desc\": \"High inequality, low rates, global capital flood.\",\n",
        "        \"probability\": 0.15\n",
        "    },\n",
        "    \"Goldilocks\": {\n",
        "        \"base_rate\": 0.045, # 4.5% annual growth (Steady beat of inflation)\n",
        "        \"desc\": \"Steady wages, moderate supply, stability.\",\n",
        "        \"probability\": 0.30\n",
        "    },\n",
        "    \"Base Case (Stagnation)\": {\n",
        "        \"base_rate\": 0.025, # 2.5% annual growth (Just tracking inflation)\n",
        "        \"desc\": \"Aging population, sluggish economy, flat real prices.\",\n",
        "        \"probability\": 0.35\n",
        "    },\n",
        "    \"Socialist Correction\": {\n",
        "        \"base_rate\": -0.01, # -1% annual nominal drop (Significant real drop)\n",
        "        \"desc\": \"Rent controls, high taxes, landlord sell-off.\",\n",
        "        \"probability\": 0.15\n",
        "    },\n",
        "    \"Climate Crunch\": {\n",
        "        \"base_rate\": -0.04, # -4% annual crash (Systemic failure)\n",
        "        \"desc\": \"Insurance crisis, banks withdraw lending.\",\n",
        "        \"probability\": 0.05\n",
        "    }\n",
        "}\n",
        "\n",
        "# ==========================================\n",
        "#  CALCULATION ENGINE (THE MICRO LAYER)\n",
        "# ==========================================\n",
        "\n",
        "def calculate_micro_modifiers(scenario_name, inputs):\n",
        "    \"\"\"\n",
        "    Adjusts the base national rate based on local property variables.\n",
        "    Different scenarios treat local variables differently.\n",
        "    \"\"\"\n",
        "    adj = 0.0\n",
        "\n",
        "    # --- 1. Affordability Logic ---\n",
        "    if inputs['affordability'] == 'High_Headroom':\n",
        "        adj += 0.015  # Catch-up growth potential (+1.5%)\n",
        "    elif inputs['affordability'] == 'Maxed_Out':\n",
        "        # In Gilded Age, London defies gravity. In others, it drags.\n",
        "        if scenario_name == \"New Gilded Age\":\n",
        "            adj += 0.02 # London premium returns\n",
        "        else:\n",
        "            adj -= 0.01 # Affordability ceiling drags growth\n",
        "\n",
        "    # --- 2. Agglomeration Logic ---\n",
        "    if inputs['economy'] == 'Tech_Hub':\n",
        "        adj += 0.015  # Jobs create gravity\n",
        "    elif inputs['economy'] == 'Stagnant':\n",
        "        adj -= 0.015  # Brain drain\n",
        "\n",
        "    # --- 3. Property Tenure Logic ---\n",
        "    if inputs['type'] == 'Leasehold_Flat':\n",
        "        # Service charges erode capital growth\n",
        "        adj -= 0.01\n",
        "        # In 'Socialist Correction', leasehold reform might help, but generally it's a drag\n",
        "    elif inputs['type'] == 'Freehold_House':\n",
        "        adj += 0.005  # Scarcity premium\n",
        "\n",
        "    # --- 4. Climate Logic ---\n",
        "    if inputs['risk'] == 'High':\n",
        "        if scenario_name == \"Climate Crunch\":\n",
        "            adj -= 0.15  # Asset becomes uninsurable (Crash)\n",
        "        else:\n",
        "            adj -= 0.02  # General market discount for risk\n",
        "\n",
        "    return adj\n",
        "\n",
        "# ==========================================\n",
        "#  RUN SIMULATION\n",
        "# ==========================================\n",
        "\n",
        "results = []\n",
        "annual_data = {year: [] for year in range(2025, 2025 + years + 1)}\n",
        "annual_data['Year'] = list(range(2025, 2025 + years + 1))\n",
        "\n",
        "print(f\"--- SIMULATION REPORT: 2025-{2025+years} ---\")\n",
        "print(f\"Property: {property_type} in {local_economy} economy ({affordability_status} Affordability)\")\n",
        "print(f\"Starting Price: £{current_price:,.0f}\\n\")\n",
        "\n",
        "weighted_fv = 0\n",
        "\n",
        "for name, data in scenarios.items():\n",
        "    # 1. Get Base Rate\n",
        "    base_rate = data['base_rate']\n",
        "\n",
        "    # 2. Calculate Local Adjustments\n",
        "    user_inputs = {\n",
        "        'affordability': affordability_status,\n",
        "        'economy': local_economy,\n",
        "        'type': property_type,\n",
        "        'risk': climate_risk\n",
        "    }\n",
        "    micro_modifier = calculate_micro_modifiers(name, user_inputs)\n",
        "\n",
        "    # 3. Final Effective Annual Rate\n",
        "    final_rate = base_rate + micro_modifier\n",
        "\n",
        "    # 4. Compound Growth\n",
        "    future_value = current_price * ((1 + final_rate) ** years)\n",
        "    total_growth_pct = ((future_value - current_price) / current_price) * 100\n",
        "\n",
        "    # Store for Weighted Average\n",
        "    weighted_fv += future_value * data['probability']\n",
        "\n",
        "    # Store for Plotting\n",
        "    prices = [current_price * ((1 + final_rate) ** i) for i in range(years + 1)]\n",
        "    annual_data[name] = prices\n",
        "\n",
        "    # Output Summary\n",
        "    print(f\"SCENARIO: {name.upper()}\")\n",
        "    print(f\"  > Narrative: {data['desc']}\")\n",
        "    print(f\"  > Base Rate: {base_rate*100:.1f}% | Local Adj: {micro_modifier*100:+.1f}% | Final Rate: {final_rate*100:.1f}%\")\n",
        "    print(f\"  > 2040 Value: £{future_value:,.0f} ({total_growth_pct:+.0f}%)\")\n",
        "    print(\"-\" * 40)\n",
        "\n",
        "# ==========================================\n",
        "#  FINAL WEIGHTED ANALYSIS\n",
        "# ==========================================\n",
        "\n",
        "print(f\"\\n>>> PROBABILISTIC FORECAST (Weighted Average) <<<\")\n",
        "weighted_growth = ((weighted_fv - current_price) / current_price) * 100\n",
        "print(f\"Expected Value (2040): £{weighted_fv:,.0f}\")\n",
        "print(f\"Expected Total Return: {weighted_growth:+.1f}%\")\n",
        "\n",
        "# ==========================================\n",
        "#  VISUALIZATION\n",
        "# ==========================================\n",
        "\n",
        "try:\n",
        "    df = pd.DataFrame(annual_data)\n",
        "    plt.figure(figsize=(12, 7))\n",
        "\n",
        "    # Plot each scenario\n",
        "    for name in scenarios.keys():\n",
        "        plt.plot(df['Year'], df[name], label=name, linewidth=2)\n",
        "\n",
        "    # Plot Weighted Average (Dotted Line)\n",
        "    weighted_line = [sum(df.loc[i, s] * scenarios[s]['probability'] for s in scenarios) for i in range(len(df))]\n",
        "    plt.plot(df['Year'], weighted_line, 'k--', label='Weighted Probability', linewidth=2.5)\n",
        "\n",
        "    plt.title(f\"UK House Price Forecast (2025-2040)\\n{property_type} | {local_economy} | {affordability_status}\", fontsize=14)\n",
        "    plt.xlabel(\"Year\")\n",
        "    plt.ylabel(\"Price (£)\")\n",
        "    plt.grid(True, linestyle='--', alpha=0.6)\n",
        "    plt.legend()\n",
        "    plt.formatter = plt.FuncFormatter(lambda x, p: format(int(x), ','))\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "    print(\"\\nGraph generated successfully.\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(f\"\\n(Could not generate graph: {e})\")"
      ],
